  'Full Stack Developer': ['JavaScript', 'React', 'Node.js', 'SQL', 'MongoDB', 'REST APIs', 'Git', 'DevOps Basics'],
  'Cloud Architect': ['AWS', 'Azure', 'GCP', 'Networking', 'Security', 'Infrastructure as Code', 'Microservices', 'Kubernetes'],
};

Deno.serve(async (req: Request) => {
  if (req.method === 'OPTIONS') {
    return new Response(null, {
      status: 200,
      headers: corsHeaders,
    });
  }

  try {
    const { user_id, target_role, current_skills } = await req.json();

    const supabaseUrl = Deno.env.get('SUPABASE_URL')!;
    const supabaseKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!;
    const supabase = createClient(supabaseUrl, supabaseKey);

    let requiredSkills: string[] = [];

    if (roleSkillsDatabase[target_role]) {
      requiredSkills = roleSkillsDatabase[target_role];
    } else {
      const openaiKey = Deno.env.get('OPENAI_API_KEY');

      if (openaiKey) {
        const aiResponse = await fetch('https://api.openai.com/v1/chat/completions', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${openaiKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            model: 'gpt-4',
            messages: [
              { role: 'system', content: 'You are a career advisor expert.' },
              { role: 'user', content: `List 8-10 essential skills required for a ${target_role} role. Return only a JSON array of skill names.` },
            ],
            temperature: 0.5,
          }),
        });

        const aiData = await aiResponse.json();
        requiredSkills = JSON.parse(aiData.choices[0].message.content);
      } else {
        requiredSkills = ['Communication', 'Problem Solving', 'Critical Thinking', 'Teamwork', 'Technical Skills', 'Project Management'];
      }
    }

    const currentSkillsLower = current_skills.map((s: string) => s.toLowerCase());
    const matchedSkills = requiredSkills.filter((skill) =>
      currentSkillsLower.some((cs) => cs.includes(skill.toLowerCase()) || skill.toLowerCase().includes(cs))
    );
    const missingSkills = requiredSkills.filter((skill) => !matchedSkills.includes(skill));
    const skillMatchPercentage = Math.round((matchedSkills.length / requiredSkills.length) * 100);

    const skillGap = {
      id: crypto.randomUUID(),
      user_id,
      target_role,
      current_skills: matchedSkills,
      required_skills: requiredSkills,
      missing_skills: missingSkills,
      skill_match_percentage: skillMatchPercentage,
      created_at: new Date().toISOString(),
    };

    const { error: insertError } = await supabase
      .from('skill_gaps')
      .insert(skillGap);

    if (insertError) throw insertError;

    return new Response(
      JSON.stringify({ skill_gap: skillGap }),
      {
        headers: {
          ...corsHeaders,
          'Content-Type': 'application/json',
        },
      }
    );
  } catch (error) {
    return new Response(
      JSON.stringify({ error: error.message }),
      {
        status: 500,
        headers: {
          ...corsHeaders,
          'Content-Type': 'application/json',
        },
      }
    );
  }
});
import { createClient } from 'npm:@supabase/supabase-js@2';

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type, Authorization, X-Client-Info, Apikey',
};

function generateMockFeedback(answer: string, questionIndex: number): string {
  const feedbackTemplates = [
    'Good foundational understanding. Consider adding more specific examples to strengthen your response.',
    'Strong technical knowledge demonstrated. Try to elaborate on the practical applications.',
    'Clear explanation. You could improve by discussing edge cases or limitations.',
    'Solid answer. Adding real-world scenarios would make your response more compelling.',
    'Well articulated. Consider mentioning how this relates to current industry practices.',
  ];
  return feedbackTemplates[questionIndex % feedbackTemplates.length];
}

function calculateScores(answers: string[]): { overall: number; communication: number; technical: number; clarity: number } {
  const avgLength = answers.reduce((sum, ans) => sum + ans.length, 0) / answers.length;

  const communication = Math.min(100, Math.round((avgLength / 200) * 100));
  const technical = Math.round(60 + Math.random() * 30);
  const clarity = Math.round(65 + Math.random() * 25);
  const overall = Math.round((communication + technical + clarity) / 3);

  return {
    overall: Math.min(100, overall),
    communication: Math.min(100, communication),
    technical: Math.min(100, technical),
    clarity: Math.min(100, clarity),
  };
}

Deno.serve(async (req: Request) => {
  if (req.method === 'OPTIONS') {
    return new Response(null, {
      status: 200,
      headers: corsHeaders,
    });
  }

  try {
    const { interview_id, user_id, answers } = await req.json();

    const supabaseUrl = Deno.env.get('SUPABASE_URL')!;
    const supabaseKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!;
    const supabase = createClient(supabaseUrl, supabaseKey);

    const { data: interviewData } = await supabase
      .from('interviews')
      .select('*')
      .eq('id', interview_id)
      .maybeSingle();

    if (!interviewData) {
      throw new Error('Interview not found');
    }

    let feedback: string[] = [];
    const openaiKey = Deno.env.get('OPENAI_API_KEY');

    if (openaiKey) {
      const aiPrompt = `Evaluate these interview answers and provide constructive feedback for each.

      Questions and Answers:
      ${interviewData.questions.map((q: string, i: number) => `Q${i + 1}: ${q}\nA${i + 1}: ${answers[i]}`).join('\n\n')}

      Provide:
      1. Specific feedback for each answer (as a JSON array of strings)
      2. Scores (0-100) for: overall, communication, technical, clarity (as a JSON object)

      Format: { "feedback": ["feedback1", "feedback2", ...], "scores": { "overall": 0, "communication": 0, "technical": 0, "clarity": 0 } }`;

      const aiResponse = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${openaiKey}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'gpt-4',
          messages: [
            { role: 'system', content: 'You are an expert interviewer providing constructive feedback.' },
            { role: 'user', content: aiPrompt },
          ],
          temperature: 0.7,
        }),
      });

      const aiData = await aiResponse.json();
      const result = JSON.parse(aiData.choices[0].message.content);
      feedback = result.feedback;

      const { error: updateError } = await supabase
        .from('interviews')
        .update({
          answers,
          feedback: result.feedback,
          overall_score: result.scores.overall,
          communication_score: result.scores.communication,
          technical_score: result.scores.technical,
          clarity_score: result.scores.clarity,
          status: 'completed',
          completed_at: new Date().toISOString(),
        })
        .eq('id', interview_id);

      if (updateError) throw updateError;
    } else {
      feedback = answers.map((ans, idx) => generateMockFeedback(ans, idx));
      const scores = calculateScores(answers);

      const { error: updateError } = await supabase
        .from('interviews')
        .update({
          answers,
          feedback,
          overall_score: scores.overall,
          communication_score: scores.communication,
          technical_score: scores.technical,
          clarity_score: scores.clarity,
          status: 'completed',
          completed_at: new Date().toISOString(),
        })
        .eq('id', interview_id);

      if (updateError) throw updateError;
    }

    const { data: updatedInterview } = await supabase
      .from('interviews')
      .select('*')
      .eq('id', interview_id)
      .maybeSingle();

    return new Response(
      JSON.stringify({ interview: updatedInterview }),
      {
        headers: {
          ...corsHeaders,
          'Content-Type': 'application/json',
        },
      }
    );
  } catch (error) {
    return new Response(
      JSON.stringify({ error: error.message }),
      {
        status: 500,
        headers: {
          ...corsHeaders,
          'Content-Type': 'application/json',
        },
      }
    );
  }
});
