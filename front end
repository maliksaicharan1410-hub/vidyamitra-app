const roleSkillsDatabase: Record<string, string[]> = {
  'Software Engineer': ['JavaScript', 'Python', 'Java', 'Git', 'Data Structures', 'Algorithms', 'REST APIs', 'SQL', 'Testing'],
  'Data Scientist': ['Python', 'R', 'SQL', 'Machine Learning', 'Statistics', 'Data Visualization', 'Pandas', 'NumPy', 'Scikit-learn'],
